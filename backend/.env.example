# Database (shared)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=noh_hospital

# Server
PORT=5001
NODE_ENV=development

# JWT (admin)
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES=7d

# Upload (admin)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=2097152

# Optional: set comma-separated origins for CORS
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174

